;; giemon_caterpillar_facade — dual-track UGV facade/street-cleaning chassis
;; + chassis-mounted cleaning boom, as EDN.
;;
;; clj/edn が主 (ADR-0040/0042/0046, giemon_arm6.edn踏襲): 本EDNが正本。
;; giemon_caterpillar_facade.urdf は :chassis/boom(:arm/chain)部分に限る
;; parity oracle として、from_edn(edn) == parse_urdf(urdf) を検証する。
;; トラック駆動ベース(:chassis/drive)とビジュアル部品構成
;; (:chassis/base-geometry)はURDFのkinematic tree(木構造の関節連鎖)で
;; 自然に表現できないためEDN専用 — 詳細は :chassis/realization :unresolved。
;;
;; ベースシャシーの寸法・部品構成は orgs/kotoba-lang/kami-app-giemon の
;; kami_app_giemon.caterpillar(レガシー kami-app-giemon Rust crateの1:1 clj
;; 移植)の実寸法から出典(:chassis/base-geometry、y-upレンダラ座標系のまま
;; 引用 — 本フィクスチャのz-up robotics座標系への軸読み替えは未実施)。
;; ブーム(:chassis/boom)はgiemon_arm6と同じrevolute-joint-chainパターンを
;; そのまま再利用した新規追加コンポーネント(kotoba.giemon.arm変更なし)。
;;
;; Datomic/Datascript tx-data 形式(scripts/edn-datomize.bb wrap-generic、
;; giemon_arm6.edn/split_contract.edn と同一方針): トップレベルは
;; [{:db/id -1 ...}] で、非scalar値(map)は pr-str blob として保持する。
;; blob の読み方は test/kotoba/giemon/chassis_edn_test.clj の unblob/
;; reconstitute-chassis を参照(test/kotoba/giemon/arm_edn_test.clj と同型)。
;;
;; Units: metres / kg / kg·m² / N·m / m/s / rad/s.
[{:chassis/name "giemon_caterpillar_facade", :chassis/base "#:link{:name \"base_link\", :inertial {:origin [0 0 0.04], :mass 9.5, :inertia {:ixx 0.05, :iyy 0.09, :izz 0.08, :ixy 0, :ixz 0, :iyz 0}}}", :chassis/realization "{:status :draft, :default :dry-brush-only, :torque-rule \"連続(定格)トルク = ピークの1/2〜1/3。関節選定は連続値で評価する(giemon_arm6と同一方針)。\", :single-source \"各:chassis/boom joint の:joint/limit(effort)と:joint/actuator(cont-nm)を\\n                  同じ場所に置く。variantの差分は:variantsの:overrideで表し、別の:bomリストで\\n                  二重管理しない。kotoba.giemon.chassis/boom-armがこのmapを:chassis/boomへjoinする。\", :variants {:dry-brush-only {:payload-fluid-l 0, :total-jpy \"~16.3万(ブームアクチュエータ4点の小計のみ、走行モーター等は:chassis/drive参照・別勘定)\", :note \"ブラシのみ、清掃液タンク非搭載。上の:chassis/boom :arm/chainの:joint/actuatorがこの構成。\"}, :wet-spray {:payload-fluid-l 3.0, :total-jpy \"~30.1万(同上、boom_lift差し替え後)\", :note \"スプレーノズル+清掃液タンク(:chassis/payload :cleaning-fluid-tank)搭載。\\n          タンク満載時のブーム基部モーメント増加に対応してj_boom_liftのみ上位アクチュエータへ差し替え。\", :override {\"j_boom_lift\" {:role :boom-lift, :comm #{:ethercat :canopen}, :price-jpy 180000, :enc :abs, :mass-kg 2.1, :peak-nm 160, :ratio \"100:1\", :cont-nm 55, :model \"Harmonic Drive FHA-14C-100\"}}}}, :unresolved [\"ノズル手首(j_nozzle_wrist)を単機で満たす小型軽量アクチュエータは連続2.5N·mで要求3N·mに僅かに不足 -- underrated-joints で検出される既知ギャップ。次段階で僅かに上位の小型機への差し替えが必要。\" \"走行モーター(:chassis/drive :left-motor/:right-motor)の連続トルク要求は車重・路面摩擦・登坂角・目標加速度から計算する車両ダイナミクスの仕事であり、本フィクスチャでは未計算 -- 現在の部品選定(MY1020Z系)は同クラスの完成クローラキットからの類推であり実測スペックシート未確証。\" \":chassis/base-geometry のtranslate-mは出典(kami-app-giemon、y-upレンダラ座標系)のまま引用しており、本フィクスチャのz-up robotics座標系への軸読み替えは未実施 -- そのままロボティクスframeの姿勢として消費しないこと。\" \":wet-spray構成でタンク満載時(:chassis/payload :cleaning-fluid-tank :full-mass-kg 3.2)の重心シフトが車両の静的/動的安定性(特に旋回時の転倒余裕)に与える影響は未検証。\" \"boom_lift/boom_reachを最大リーチまで伸ばした状態でタンク満載時の実効モーメントは、j_boom_liftの静止時torque-headroom(連続40N·mに対し要求25N·m)だけでは十分に検証されていない -- 多体動力学での伸長状態チェックが別途必要。\" \"CubeMars AK10-9の実勢価格・国内代理店の有無は未確証(giemon_arm6の既存不明点と同種)。\"]}", :chassis/base-geometry "{:source \"orgs/kotoba-lang/kami-app-giemon/src/kami_app_giemon/caterpillar.cljc (read-only citation, 2026-07-18時点)\", :frame :kami-app-giemon-render-yup, :note \"dims-mは信頼できる実寸法(メートル)。translate-mは出典のy-upレンダラ座標系のまま引用 — 本フィクスチャのz-up robotics座標系への軸読み替えは未実施。そのままロボティクスframeの姿勢として消費しないこと(:chassis/realization :unresolved参照)。\", :parts [#:part{:id \"cat_body\", :name \"Chassis Armour\", :dims-m [0.38 0.08 0.2], :translate-m [0.0 0.04 0.0]} #:part{:id \"cat_track_l\", :name \"Left Track\", :dims-m [0.4 0.06 0.065], :translate-m [0.0 0.03 -0.132]} #:part{:id \"cat_track_r\", :name \"Right Track\", :dims-m [0.4 0.06 0.065], :translate-m [0.0 0.03 0.132]} #:part{:id \"cat_wh_l0\", :name \"Drive Wheel L1\", :dims-m [0.021 0.052 0.021], :translate-m [-0.15 0.02 -0.132], :note \"cylinder r=0.021 h=0.052, rotated 90 deg about x\"} #:part{:id \"cat_wh_l1\", :name \"Drive Wheel L2\", :dims-m [0.021 0.052 0.021], :translate-m [-0.09 0.02 -0.132]} #:part{:id \"cat_wh_l2\", :name \"Drive Wheel L3\", :dims-m [0.021 0.052 0.021], :translate-m [-0.03 0.02 -0.132]} #:part{:id \"cat_wh_l3\", :name \"Drive Wheel L4\", :dims-m [0.021 0.052 0.021], :translate-m [0.03 0.02 -0.132]} #:part{:id \"cat_wh_l4\", :name \"Drive Wheel L5\", :dims-m [0.021 0.052 0.021], :translate-m [0.09 0.02 -0.132]} #:part{:id \"cat_wh_l5\", :name \"Drive Wheel L6\", :dims-m [0.021 0.052 0.021], :translate-m [0.15 0.02 -0.132]} #:part{:id \"cat_wh_r0\", :name \"Drive Wheel R1\", :dims-m [0.021 0.052 0.021], :translate-m [-0.15 0.02 0.132]} #:part{:id \"cat_wh_r1\", :name \"Drive Wheel R2\", :dims-m [0.021 0.052 0.021], :translate-m [-0.09 0.02 0.132]} #:part{:id \"cat_wh_r2\", :name \"Drive Wheel R3\", :dims-m [0.021 0.052 0.021], :translate-m [-0.03 0.02 0.132]} #:part{:id \"cat_wh_r3\", :name \"Drive Wheel R4\", :dims-m [0.021 0.052 0.021], :translate-m [0.03 0.02 0.132]} #:part{:id \"cat_wh_r4\", :name \"Drive Wheel R5\", :dims-m [0.021 0.052 0.021], :translate-m [0.09 0.02 0.132]} #:part{:id \"cat_wh