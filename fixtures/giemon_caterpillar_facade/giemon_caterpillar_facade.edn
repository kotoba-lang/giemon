emon_caterpillar_facade_boom\", :dof 4, :units {:length :m, :mass :kg, :inertia :kg-m2, :torque :n-m}, :convention \"boom stacks along +z from a rear-mounted mast on base_link; z(yaw)-y(lift)-y(elbow)-x(wrist)\", :chain [{:joint/axis [0 0 1], :joint/type :revolute, :joint/name \"j_boom_yaw\", :joint/damping 0.05, :joint/origin [-0.15 0 0.1], :joint/parent \"base_link\", :joint/child \"boom_mast_link\", :child/link #:link{:name \"boom_mast_link\", :inertial {:origin [0 0 0.025], :mass 0.4, :inertia {:ixx 4.0E-4, :iyy 4.0E-4, :izz 2.0E-4}}}, :joint/actuator {:role :boom-yaw, :comm :can, :price-jpy 60000, :enc :abs-single-turn, :mass-kg 0.521, :note \"effort8に対し連続8.3、余裕僅少\", :peak-nm 24.8, :buy \"Foxtech/CubeMars\", :cont-nm 8.3, :model \"CubeMars AK70-10\"}, :joint/limit {:lower -2.0, :upper 2.0, :effort 8, :velocity 2.5}} {:joint/axis [0 1 0], :joint/type :revolute, :joint/name \"j_boom_lift\", :joint/damping 0.08, :joint/origin [0 0 0.05], :joint/parent \"boom_mast_link\", :joint/child \"boom_link1\", :child/link #:link{:name \"boom_link1\", :inertial {:origin [0 0 0.175], :mass 0.9, :inertia {:ixx 0.012, :iyy 0.012, :izz 0.001}}}, :joint/actuator {:role :boom-lift, :comm :can, :price-jpy 42000, :enc :abs-single-turn, :mass-kg 1.42, :peak-nm 120, :buy \"OpenELAB(EU)/Taobao\", :ratio \"9:1\", :cont-nm 40, :model \"RobStride 04\"}, :joint/limit {:lower -0.2, :upper 1.6, :effort 25, :velocity 1.5}} {:joint/axis [0 1 0], :joint/type :revolute, :joint/name \"j_boom_reach\", :joint/damping 0.06, :joint/origin [0 0 0.35], :joint/parent \"boom_link1\", :joint/child \"boom_link2\", :child/link #:link{:name \"boom_link2\", :inertial {:origin [0 0 0.15], :mass 0.6, :inertia {:ixx 0.006, :iyy 0.006, :izz 6.0E-4}}}, :joint/actuator {:role :boom-elbow, :comm :can, :price-jpy 33000, :enc :dual, :mass-kg 0.896, :peak-nm 40, :buy \"Damiao 直販/代理店\", :ratio \"9:1\", :cont-nm 20, :model \"Damiao DM-J8009-2EC\"}, :joint/limit {:lower -2.0, :upper 0.3, :effort 15, :velocity 1.5}} {:joint/axis [1 0 0], :joint/type :revolute, :joint/name \"j_nozzle_wrist\", :joint/damping 0.02, :joint/origin [0 0 0.3], :joint/parent \"boom_link2\", :joint/child \"nozzle_link\", :child/link #:link{:name \"nozzle_link\", :inertial {:origin [0 0 0.05], :mass 0.35, :inertia {:ixx 6.0E-4, :iyy 6.0E-4, :izz 3.0E-4}}}, :joint/actuator {:role :wrist, :comm :can, :price-jpy 28000, :enc :abs-single-turn, :mass-kg 0.325, :note \"effort3(要求)に対し連続2.5、僅かに力不足 -- :unresolved参照\", :peak-nm 6.9, :buy \"Foxtech/CubeMars\", :cont-nm 2.5, :model \"CubeMars AK10-9\"}, :joint/limit {:lower -1.6, :upper 1.6, :effort 3, :velocity 3}}]}", :chassis/payload "{:cleaning-fluid-tank {:capacity-l 3.0, :fluid-type \"pH中性・生分解性ファサード洗浄剤(次亜塩素酸/強酸不使用)\", :full-mass-kg 3.2, :empty-mass-kg 0.4, :mount-link \"base_link\", :mount-note \":wet-spray variant選択時のみ搭載・満載。:dry-brush-onlyでは非搭載(質量ゼロ)。\"}}", :chassis/kind :dual-track-ugv}]
