<?xml version="1.0"?>
<!-- GIEMON CATERPILLAR FACADE — chassis + cleaning-boom articulation spec
     (PARITY ORACLE, boom chain only).
     clj/edn が主 (ADR-0040/0042/0046, giemon_arm6踏襲): 正本は
     giemon_caterpillar_facade.edn。この URDF は :chassis/boom(:arm/chain)
     部分に限る parity oracle として、from_edn(edn) == parse_urdf(urdf) を
     検証する。トラック駆動ベース(:chassis/drive)とビジュアル部品構成
     (:chassis/base-geometry、出典 kami-app-giemon)はURDFのkinematic tree
     で自然に表現できないためEDN専用 -- 詳細は giemon_caterpillar_facade.edn
     の :chassis/realization :unresolved を参照。
     Units: metres / kg / kg·m². base_link is the chassis root
     (:chassis/base と同一)。-->
<robot name="giemon_caterpillar_facade">

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="9.5"/>
      <inertia ixx="0.05" iyy="0.09" izz="0.08" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="j_boom_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="boom_mast_link"/>
    <origin xyz="-0.150 0 0.10" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="8" velocity="2.5"/>
    <dynamics damping="0.05"/>
  </joint>
  <link name="boom_mast_link">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="0.4"/>
      <inertia ixx="0.0004" iyy="0.0004" izz="0.0002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="j_boom_lift" type="revolute">
    <parent link="boom_mast_link"/>
    <child link="boom_link1"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.2" upper="1.6" effort="25" velocity="1.5"/>
    <dynamics damping="0.08"/>
  </joint>
  <link name="boom_link1">
    <inertial>
      <origin xyz="0 0 0.175" rpy="0 0 0"/>
      <mass value="0.9"/>
      <inertia ixx="0.012" iyy="0.012" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="j_boom_reach" type="revolute">
    <parent link="boom_link1"/>
    <child link="boom_link2"/>
    <origin xyz="0 0 0.35" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="0.3" effort="15" velocity="1.5"/>
    <dynamics damping="0.06"/>
  </joint>
  <link name="boom_link2">
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="0.6"/>
      <inertia ixx="0.006" iyy="0.006" izz="0.0006" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="j_nozzle_wrist" type="revolute">
    <parent link="boom_link2"/>
    <child link="nozzle_link"/>
    <origin xyz="0 0 0.30" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.6" upper="1.6" effort="3" velocity="3"/>
    <dynamics damping="0.02"/>
  </joint>
  <link name="nozzle_link">
    <inertial>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia ixx="0.0006" iyy="0.0006" izz="0.0003" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

</robot>
